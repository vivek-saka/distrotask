# Used by apps/api/test/e2e/jest.setup.ts and CI. Points at the same local
# Postgres/Redis/RabbitMQ as docker-compose.yml by default — override if you
# run a separate, isolated test stack.
NODE_ENV=test

DATABASE_URL=postgresql://distrotask:dev_local_password_only@localhost:5432/distrotask?schema=public
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://distrotask:dev_local_password_only@localhost:5672

JWT_SECRET=test_jwt_secret_do_not_use_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=test_jwt_refresh_secret_do_not_use_in_production
JWT_REFRESH_EXPIRES_IN=7d

WORKER_SERVICE_TOKEN=test_worker_token_do_not_use_in_production
CORS_ORIGIN=*
