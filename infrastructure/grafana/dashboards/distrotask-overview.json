{
  "title": "DistroTask Overview",
  "uid": "distrotask-overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Active Workers",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "distrotask_active_workers", "refId": "A" }]
    },
    {
      "id": 2,
      "title": "Tasks Created (rate, 5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 0 },
      "targets": [{ "expr": "sum(rate(distrotask_tasks_created_total[5m])) by (priority)", "refId": "A" }]
    },
    {
      "id": 3,
      "title": "Queue Depth by Priority",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [{ "expr": "distrotask_queue_depth", "refId": "A" }]
    },
    {
      "id": 4,
      "title": "Worker Task Outcomes (rate, 5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "sum(rate(distrotask_worker_tasks_processed_total[5m])) by (outcome)", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "title": "Task Duration p95 (worker)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(distrotask_worker_task_duration_seconds_bucket[5m])) by (le, type))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "HTTP Request Duration p99 (API)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(distrotask_http_request_duration_seconds_bucket[5m])) by (le, route))",
          "refId": "A"
        }
      ]
    }
  ]
}
