# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
.next/
out/
build/
*.tsbuildinfo

# Environment files — never commit real secrets
.env
.env.local
.env.*.local
.env.production
!.env.example
!.env.test

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test / coverage
coverage/
.nyc_output/

# Prisma generated client output (migrations themselves ARE committed)
prisma/generated/

# IDE / editor
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
.DS_Store

# OS
Thumbs.db

# Turborepo
.turbo/

# TLS certs — never commit real certificates or keys
infrastructure/nginx/ssl/*.pem
infrastructure/nginx/ssl/*.key
infrastructure/nginx/ssl/*.crt

# Misc
*.pid
*.seed
*.pid.lock
.eslintcache
