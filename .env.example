# ── General ──────────────────────────────────────────────────────────────
NODE_ENV=development

# ── PostgreSQL ───────────────────────────────────────────────────────────
POSTGRES_USER=distrotask
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=distrotask
DATABASE_URL=postgresql://distrotask:change_me_in_production@postgres:5432/distrotask?schema=public

# ── Redis ────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── RabbitMQ ─────────────────────────────────────────────────────────────
RABBITMQ_USER=distrotask
RABBITMQ_PASSWORD=change_me_in_production
RABBITMQ_URL=amqp://distrotask:change_me_in_production@rabbitmq:5672
RABBITMQ_MANAGEMENT_PORT=15672

# ── API service ──────────────────────────────────────────────────────────
PORT=3001
CORS_ORIGIN=http://localhost:3000

# JWT — generate strong random secrets for production, e.g.:
#   openssl rand -base64 48
JWT_SECRET=replace_with_a_long_random_string_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_REFRESH_EXPIRES_IN=7d

# Shared secret the Worker service uses to authenticate internal callback
# routes (task status updates, log appends, worker registration/heartbeat).
# Must match between the api and worker services.
WORKER_SERVICE_TOKEN=replace_with_a_long_random_worker_secret

# ── Worker service ───────────────────────────────────────────────────────
API_BASE_URL=http://api:3001
WORKER_NAME=worker-1
WORKER_QUEUES=*
WORKER_CONCURRENCY=5
WORKER_HEARTBEAT_INTERVAL_MS=10000
WORKER_METRICS_PORT=9100

# ── Web dashboard ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_WS_URL=http://localhost:3001/ws

# ── Grafana ──────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_in_production
